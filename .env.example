# Required — lets the cron job commit new posts to your GitHub repo.
GITHUB_TOKEN=            # fine-grained PAT with Contents: Read & write on this repo only
GITHUB_OWNER=             # your GitHub username or org
GITHUB_REPO=              # repo name, e.g. daily-blog
GITHUB_BRANCH=main

# Required — protects /api/cron/generate from being called by strangers.
# Generate any random string, e.g. `openssl rand -hex 32`.
CRON_SECRET=

# Optional — free tier at https://ai.google.dev. If set, posts are written
# by Gemini instead of the built-in $0 template generator.
GEMINI_API_KEY=
